# PostgreSQL container configuration
# These are used by BOTH the PostgreSQL container AND the Spring Boot app
POSTGRES_DB=bossbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Spring Boot database URL for LOCAL development (native PostgreSQL on localhost:5432)
# Username and password are taken from POSTGRES_USER/POSTGRES_PASSWORD above
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bossbot

# Note: When using Docker Compose, the SPRING_DATASOURCE_URL is overridden
# in docker-compose.yaml to use 'postgres' as the hostname instead of 'localhost'
