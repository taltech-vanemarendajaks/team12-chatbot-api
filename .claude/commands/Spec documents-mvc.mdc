Controller for MVC Views (Not REST)

Update your DocumentController to return view names instead of JSON:

@Controller    // ← Not @RestController
@RequestMapping("/documents")
public class DocumentController {
    @Autowired private DocumentRepository repo;

    @GetMapping
    public String list(Model model) {
        model.addAttribute("documents", repo.findAll());
        return "documents/list";  // → templates/documents/list.html
    }

    @GetMapping("/new")
    public String createForm(Model model) {
        model.addAttribute("document", new Document());
        return "documents/form";
    }

    @PostMapping
    public String save(@ModelAttribute Document doc) {
        repo.save(doc);
        return "redirect:/documents";
    }
}
