⚙️ Backend - Spring Boot JPA

entity/Document.java

@Entity
@Table(name = "documents")
public class Document {
    @Id @GeneratedValue(strategy = IDENTITY)
    private Long id;
    
    private String filename;
    private String contentType;
    
    @Lob
    @Column(columnDefinition = "bytea")
    private byte[] content;
    
    @Column(name = "embedding", columnDefinition = "vector(1536)")
    private float[] embedding;
    
    @Column(columnDefinition = "text")
    private String contentText;
    
    // Constructors, getters, setters
}
DocumentController.java

@RestController
@RequestMapping("/api/documents")
@CrossOrigin(origins = "http://localhost:3000")
public class DocumentController {
    
    @PostMapping("/upload")
    public ResponseEntity<List<DocumentDTO>> upload(
            @RequestParam("files") MultipartFile[] files) {
        return ResponseEntity.ok(service.uploadDocuments(files));
    }
    
    @PostMapping("/search")
    public ResponseEntity<List<DocumentDTO>> semanticSearch(@RequestBody SearchRequest req) {
        return ResponseEntity.ok(service.findSimilar(req.getQuery()));
    }
}
🚀 Quick Start

# 1. Start Postgres + pgvector
docker-compose up -d postgres

# 2. Backend
cd backend
mvn spring-boot:run

# 3. Frontend
cd frontend
npm install
npm run dev
🔗 API Endpoints

POST  /api/documents/upload    → Upload files → pgvector embeddings
POST  /api/documents/search    → "Find docs about X" → cosine similarity
GET   /api/documents           → List all docs
